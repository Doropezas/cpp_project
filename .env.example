# Copy this file to .env and fill in your actual keys.
# .env is in .gitignore — never commit it.
#
# Databento: https://app.databento.com/portal/keys
DATABENTO_API_KEY=your_databento_key_here

# FRED (Federal Reserve): https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_key_here
